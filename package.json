{
  "name": "raycast-window-layout",
  "version": "0.1.0",
  "private": true,
  "description": "Raycast extension to save and restore named macOS window layouts via yabai.",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "ray develop",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@raycast/api": "^1.95.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "raycast": {
    "schemaVersion": 1,
    "title": "Window Layout Restore",
    "commands": [
      {
        "name": "save-layout",
        "title": "Save Layout",
        "mode": "view"
      },
      {
        "name": "restore-layout",
        "title": "Restore Layout",
        "mode": "view"
      },
      {
        "name": "manage-layouts",
        "title": "Manage Layouts",
        "mode": "view"
      }
    ]
  }
}
